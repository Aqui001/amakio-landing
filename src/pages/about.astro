          <svg class="theme-moon h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
        </button>
        <a href="https://amakio-frontend.vercel.app" class="rounded-lg px-5 py-2.5 text-sm font-semibold text-white transition-all" style="background: var(--primary); &:hover { transform: translateY(-1px); box-shadow: 0 8px 24px rgba(212,160,23,0.25); }">Get Started</a>
      </div>
    </div>
  </nav>

  <main class="pt-24">
    <!-- Hero -->
    <section class="px-6 py-20 md:py-28">
      <div class="mx-auto max-w-4xl">
        <div class="flex flex-col items-center gap-10 md:flex-row md:items-start">
          <div class="h-52 w-52 flex-shrink-0 overflow-hidden rounded-2xl border-2" style="border-color: var(--secondary);">
            <img src="/Aquilo-Dominic.png" alt="Aquilo-Dominic Godwin Udo" class="h-full w-full rounded-2xl object-cover">
          </div>
          <div>
            <p class="mb-1 text-xs font-semibold uppercase tracking-widest" style="color: var(--secondary);">Founder — Amakio</p>
            <h1 class="mb-2 text-3xl font-extrabold tracking-tight md:text-4xl" style="color: var(--text);">Aquilo-Dominic<br />Godwin Udo</h1>
            <p class="mb-4 text-base leading-relaxed" style="color: var(--text-muted);">Empowered by Faith. Driven by Purpose. Committed to Excellence.</p>
            <p class="mb-6 max-w-xl text-sm leading-relaxed" style="color: var(--text-dim);">Integrating Education, Technology, and Ministry for Transformational Impact.</p>
            <div class="flex flex-wrap gap-3">
              <a href="https://amakio-frontend.vercel.app" class="rounded-lg px-5 py-2.5 text-sm font-semibold text-white transition-all" style="background: var(--primary); &:hover { transform: translateY(-1px); box-shadow: 0 8px 24px rgba(212,160,23,0.25); }">Explore Amakio</a>
              <a href="https://linkedin.com/in/aquilo-dominic" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 rounded-lg px-4 py-2.5 text-sm font-semibold transition-all" style="color: var(--primary); border: 1px solid var(--border); &:hover { border-color: var(--secondary); }">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
              <a href="https://github.com/Aqui001" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 rounded-lg px-4 py-2.5 text-sm font-semibold transition-all" style="color: var(--primary); border: 1px solid var(--border); &:hover { border-color: var(--secondary); }">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
                GitHub
              </a>
              <a href="mailto:officialaquilo@outlook.com" class="flex items-center gap-2 rounded-lg px-4 py-2.5 text-sm font-semibold transition-all" style="color: var(--primary); border: 1px solid var(--border); &:hover { border-color: var(--secondary); }">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
