---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About — Amakio Founder" description="Aquilo-Dominic Godwin Udo — Educator, Educational Consultant, Data Analyst, Web Developer. Building Amakio to help African schools run better.">
  <nav class="fixed top-0 left-0 right-0 z-50 border-b backdrop-blur-xl" style="border-color: var(--border); background: rgba(15,15,19,0.8);">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <a href="/" class="text-lg font-bold tracking-tight" style="color: var(--text);">amakio</a>
      <div class="flex items-center gap-6">
        <a href="/" class="text-sm font-medium transition-colors" style="color: var(--text-muted); &:hover { color: var(--text); }">Home</a>
        <a href="https://amakio-frontend.vercel.app" class="rounded-lg px-4 py-2 text-sm font-semibold text-white transition-all" style="background: var(--accent); &:hover { transform: translateY(-1px); box-shadow: 0 8px 24px rgba(124,58,237,0.3); }">Get Started</a>
      </div>
    </div>
  </nav>

  <main class="pt-24">
    <!-- Founder Hero -->
    <section class="px-6 py-16 md:py-24">
      <div class="mx-auto max-w-4xl">
        <div class="flex flex-col items-center gap-8 md:flex-row md:items-start">
          <div class="h-48 w-48 flex-shrink-0 overflow-hidden rounded-2xl border-2" style="border-color: var(--accent);">
            <div class="flex h-full w-full items-center justify-center text-5xl font-bold" style="background: rgba(124,58,237,0.1); color: var(--accent-light);">AD</div>
          </div>
          <div>
            <p class="mb-1 text-sm font-semibold uppercase tracking-widest" style="color: var(--accent-light);">Founder &amp; Developer</p>
            <h1 class="mb-3 text-3xl font-bold md:text-4xl" style="color: var(--text);">Aquilo-Dominic Godwin Udo</h1>
            <p class="mb-4 text-lg leading-relaxed" style="color: var(--text-muted);">
              Educator. Educational Consultant. Data Analyst. Web Developer.
            </p>
            <p class="mb-6 leading-relaxed" style="color: var(--text-muted);">
              I built Amakio because I saw firsthand how many African schools still rely on scattered filing cabinets,
              lost records, and manual report cards. Every child deserves a school that runs well — and every teacher
              deserves tools that make their job easier, not harder.
            </p>
            <div class="flex flex-wrap gap-4">
              <a href="https://linkedin.com/in/aquilo-dominic" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-semibold transition-all" style="color: var(--text); border: 1px solid var(--border); &:hover { border-color: var(--accent); }">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
              <a href="https://github.com/Aqui001" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-semibold transition-all" style="color: var(--text); border: 1px solid var(--border); &:hover { border-color: var(--accent); }">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
                GitHub
              </a>
              <a href="mailto:officialaquilo@outlook.com" class="flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-semibold transition-all" style="color: var(--text); border: 1px solid var(--border); &:hover { border-color: var(--accent); }">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                Email
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Story -->
    <section class="border-y px-6 py-16" style="border-color: var(--border);">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-8 text-2xl font-bold" style="color: var(--text);">My story</h2>
        <div class="space-y-4 leading-relaxed" style="color: var(--text-muted);">
          <p>
            I grew up in Uyo, Akwa Ibom State, where I attended primary and secondary school before earning my B.A.Ed. in
            English Education from the University of Uyo. From a young age, I was drawn to two things: teaching and
            building.
          </p>
          <p>
            For years I worked across classrooms and school offices — helping students learn, designing curricula, and
            watching administrators struggle with mountains of paper records. I saw schools lose exam results, double-pay
            teachers, and spend weeks compiling report cards by hand.
          </p>
          <p>
            I knew technology could solve this. So I taught myself to code — starting with HTML and CSS, then JavaScript,
            TypeScript, Python, and full-stack development with Node.js, React, and PostgreSQL. I built systems for
            educational consulting first, then realised the real gap wasn't consulting tools — it was school management
            software built for how African schools actually work.
          </p>
          <p>
            That realisation became Amakio. I set out to build a platform that handles everything — from nursery
            developmental tracking and admissions to report cards and fee management — in a single, secure, easy-to-use
            system.
          </p>
        </div>
      </div>
    </section>

    <!-- Experience & skills -->
    <section class="px-6 py-16">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-12 text-center text-2xl font-bold" style="color: var(--text);">Experience &amp; Skills</h2>
        <div class="grid gap-8 md:grid-cols-2">
          <div>
            <h3 class="mb-4 text-lg font-semibold" style="color: var(--text);">Experience</h3>
            <div class="space-y-6">
              <div>
                <p class="font-medium" style="color: var(--text);">Founder &amp; Developer — Amakio</p>
                <p class="text-sm" style="color: var(--text-dim);">2024 – Present</p>
                <p class="mt-1 text-sm" style="color: var(--text-muted);">Building a school management platform for African schools. Full-stack development, product design, and deployment.</p>
              </div>
              <div>
                <p class="font-medium" style="color: var(--text);">Educational Consultant</p>
                <p class="text-sm" style="color: var(--text-dim);">2020 – Present</p>
                <p class="mt-1 text-sm" style="color: var(--text-muted);">Curriculum design, school system evaluation, and teacher training for private schools in Akwa Ibom.</p>
              </div>
              <div>
                <p class="font-medium" style="color: var(--text);">Educator — English Language &amp; Literature</p>
                <p class="text-sm" style="color: var(--text-dim);">2018 – Present</p>
                <p class="mt-1 text-sm" style="color: var(--text-muted);">Teaching English Language and Literature-in-English at secondary school level. Lesson planning, exam development, and student mentoring.</p>
              </div>
            </div>
          </div>
          <div>
            <h3 class="mb-4 text-lg font-semibold" style="color: var(--text);">Skills</h3>
            <div class="space-y-4">
              <div>
                <p class="mb-2 text-sm font-medium" style="color: var(--text);">Frontend</p>
                <div class="flex flex-wrap gap-2">
                  <span class="rounded-md px-3 py-1 text-xs font-medium" style="background: rgba(124,58,237,0.1); color: var(--accent-light);">React</span>
                  <span class="rounded-md px-3 py-1 text-xs font-medium" style="background: rgba(124,58,237,0.1); color: var(--accent-light);">TypeScript</span>
                  <span class="rounded-md px-3 py-1 text-xs font-medium" style="background: rgba(124,58,237,0.1); color: var(--accent-light);">Tailwind CSS</span>
                  <span class="rounded-md px-3 py-1 text-xs font-medium" style="background: rgba(124,58,237,0.1); color: var(--accent-light);">Astro</span>
                  <span class="rounded-md px-3 py-1 text-xs font-medium" style="background: rgba(124,58,237,0.1); color: var(--accent-light);">Vue</span>
                </div>
              </div>
              <div>
                <p class="mb-2 text-sm font-medium" style="color: var(--text);">Backend</p>
                <div class="flex flex-wrap gap-2">
                  <span class="rounded-md px-3 py-1 text-xs font-medium" style="background: rgba(124,58,237,0.1); color: var(--accent-light);">Node.js</span>
                  <span class="rounded-md px-3 py-1 text-xs font-medium" style="background: rgba(124,58,237,0.1); color: var(--accent-light);">Nitro</span>
                  <span class="rounded-md px-3 py-1 text-xs font-medium" style="background: rgba(124,58,237,0.1); color: var(--accent-light);">Python</span>
                  <span class="rounded-md px-3 py-1 text-xs font-medium" style="background: rgba(124,58,237,0.1); color: var(--accent-light);">PostgreSQL</span>
                  <span class="rounded-md px-3 py-1 text-xs font-medium" style="background: rgba(124,58,237,0.1); color: var(--accent-light);">Prisma</span>
                </div>
              </div>
              <div>
                <p class="mb-2 text-sm font-medium" style="color: var(--text);">Data &amp; Analysis</p>
                <div class="flex flex-wrap gap-2">
                  <span class="rounded-md px-3 py-1 text-xs font-medium" style="background: rgba(124,58,237,0.1); color: var(--accent-light);">SQL</span>
                  <span class="rounded-md px-3 py-1 text-xs font-medium" style="background: rgba(124,58,237,0.1); color: var(--accent-light);">Excel</span>
                  <span class="rounded-md px-3 py-1 text-xs font-medium" style="background: rgba(124,58,237,0.1); color: var(--accent-light);">Pandas</span>
                  <span class="rounded-md px-3 py-1 text-xs font-medium" style="background: rgba(124,58,237,0.1); color: var(--accent-light);">Power BI</span>
                </div>
              </div>
              <div>
                <p class="mb-2 text-sm font-medium" style="color: var(--text);">Education</p>
                <div class="flex flex-wrap gap-2">
                  <span class="rounded-md px-3 py-1 text-xs font-medium" style="background: rgba(124,58,237,0.1); color: var(--accent-light);">Curriculum Design</span>
                  <span class="rounded-md px-3 py-1 text-xs font-medium" style="background: rgba(124,58,237,0.1); color: var(--accent-light);">Exam Development</span>
                  <span class="rounded-md px-3 py-1 text-xs font-medium" style="background: rgba(124,58,237,0.1); color: var(--accent-light);">Teacher Training</span>
                  <span class="rounded-md px-3 py-1 text-xs font-medium" style="background: rgba(124,58,237,0.1); color: var(--accent-light);">EdTech Consulting</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Education -->
    <section class="border-y px-6 py-16" style="border-color: var(--border);">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-8 text-center text-2xl font-bold" style="color: var(--text);">Education</h2>
        <div class="text-center">
          <p class="text-lg font-semibold" style="color: var(--text);">B.A.Ed. English Education</p>
          <p class="text-sm" style="color: var(--text-dim);">University of Uyo, Akwa Ibom State</p>
          <p class="mt-4 leading-relaxed" style="color: var(--text-muted);">
            My background in education gives me a unique perspective on school management software.
            I understand the problems because I've lived them — in the classroom, in the staff room,
            and in the principal's office.
          </p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="px-6 py-16 text-center">
      <div class="mx-auto max-w-2xl">
        <h2 class="mb-4 text-2xl font-bold" style="color: var(--text);">Let's build better schools together</h2>
        <p class="mb-8" style="color: var(--text-muted);">
          Whether you're a school looking for a better management system or an educator who wants to collaborate, I'd love to hear from you.
        </p>
        <a href="mailto:officialaquilo@outlook.com" class="inline-block rounded-lg px-8 py-3.5 text-base font-semibold text-white transition-all" style="background: var(--accent); &:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(124,58,237,0.35); }">
          Get in touch
        </a>
      </div>
    </section>
  </main>

  <footer class="px-6 py-12" style="background: var(--surface-2);">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 md:flex-row">
      <a href="/" class="text-sm font-semibold" style="color: var(--text);">amakio</a>
      <div class="flex items-center gap-6 text-sm" style="color: var(--text-dim);">
        <a href="/" class="transition-colors" style="&:hover { color: var(--text-muted); }">Home</a>
        <a href="mailto:officialaquilo@outlook.com" class="transition-colors" style="&:hover { color: var(--text-muted); }">Contact</a>
        <span>&copy; {new Date().getFullYear()} Amakio</span>
      </div>
    </div>
  </footer>
</Layout>
