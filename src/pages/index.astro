---
import Layout from "../layouts/Layout.astro";
const year = new Date().getFullYear();
---

<Layout title="Amakio — School Management Platform for Modern Education" description="Amakio helps schools worldwide manage students, staff, academics, finance, and communication from one powerful platform.">
  <nav class="fixed top-0 left-0 right-0 z-50 border-b backdrop-blur-xl" style="border-color: var(--border); background: rgba(7,7,14,0.9);">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <a href="/" class="text-lg font-extrabold tracking-tight" style="color: var(--primary);">amakio</a>
      <div class="flex items-center gap-8">
        <a href="#modules" class="hidden text-sm font-medium transition-colors md:block" style="color: var(--text-muted); &:hover { color: var(--primary); }">Modules</a>
        <a href="#pricing" class="hidden text-sm font-medium transition-colors md:block" style="color: var(--text-muted); &:hover { color: var(--primary); }">Pricing</a>
        <a href="/about" class="text-sm font-medium transition-colors" style="color: var(--text-muted); &:hover { color: var(--primary); }">About</a>
        <button onclick="toggleTheme()" class="flex h-9 w-9 items-center justify-center rounded-lg transition-all" style="border: 1px solid var(--border); color: var(--text-muted); &:hover { border-color: var(--primary); color: var(--primary); }">
          <svg class="theme-sun h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
          <svg class="theme-moon h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
        </button>
        <a href="https://amakio-frontend.vercel.app" class="rounded-lg px-5 py-2.5 text-sm font-semibold transition-all" style="background: var(--primary); color: white; &:hover { transform: translateY(-1px); box-shadow: 0 8px 24px rgba(212,160,23,0.25); }">Get Started</a>
      </div>
    </div>
  </nav>

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden px-6 pt-36 pb-24 text-center">
      <div class="pointer-events-none absolute inset-0" style="background: radial-gradient(ellipse 800px 500px at 50% -15%, rgba(212,160,23,0.06), transparent);"></div>
      <div class="mx-auto max-w-4xl">
        <div class="mb-8 inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-sm font-semibold" style="background: rgba(212,160,23,0.1); color: var(--secondary); border: 1px solid rgba(212,160,23,0.15);">
          Built by educators, for schools everywhere
        </div>
        <h1 class="mb-6 text-5xl font-extrabold leading-tight tracking-tight md:text-6xl lg:text-7xl" style="color: var(--text);">
          The school operating<br />
          <span style="background: linear-gradient(135deg, var(--text), var(--primary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">system for modern education.</span>
        </h1>
        <p class="mx-auto mb-10 max-w-2xl text-lg leading-relaxed" style="color: var(--text-muted);">
          From student records and fee management to assessments and parent communication — Amakio brings every part of your school together in one seamless platform.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="https://amakio-frontend.vercel.app" class="rounded-lg px-8 py-3.5 text-base font-semibold text-white transition-all" style="background: var(--primary); &:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(212,160,23,0.3); }">
            Start free
          </a>
          <a href="#modules" class="rounded-lg px-8 py-3.5 text-base font-semibold transition-all" style="color: var(--text); border: 1px solid var(--border); &:hover { border-color: var(--secondary); }">
            Explore modules
          </a>
        </div>
        <p class="mt-4 text-sm" style="color: var(--text-dim);">No credit card. Free for small schools. Supports multiple currencies.</p>
      </div>
    </section>

    <!-- Problem Statement -->
    <section class="border-y px-6 py-20" style="border-color: var(--border); background: var(--surface-2);">
      <div class="mx-auto max-w-6xl">
        <div class="mb-14 text-center">
          <h2 class="mb-4 text-3xl font-bold md:text-4xl" style="color: var(--text);">The challenge facing schools today</h2>
          <p class="mx-auto max-w-2xl" style="color: var(--text-muted);">Too many schools still rely on fragmented systems, paper records, and manual processes that slow everything down.</p>
        </div>
        <div class="grid gap-5 md:grid-cols-3">
          <div class="rounded-xl border p-7 transition-all" style="border-color: var(--card-border); background: var(--surface); &:hover { border-color: rgba(212,160,23,0.5); transform: translateY(-2px); }">
            <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-lg" style="background: rgba(212,160,23,0.08);">
              <svg class="h-5 w-5" style="color: var(--primary);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold" style="color: var(--text);">Scattered records</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Student data, attendance, results, and fees live in separate spreadsheets — if they're recorded at all. Finding anything takes hours.</p>
          </div>
          <div class="rounded-xl border p-7 transition-all" style="border-color: var(--card-border); background: var(--surface); &:hover { border-color: rgba(212,160,23,0.5); transform: translateY(-2px); }">
            <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-lg" style="background: rgba(212,160,23,0.08);">
              <svg class="h-5 w-5" style="color: var(--primary);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold" style="color: var(--text);">Manual operations</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Report cards compiled by hand. Fees tracked in ledger books. Parent communication through informal channels. Too much room for error.</p>
          </div>
          <div class="rounded-xl border p-7 transition-all" style="border-color: var(--card-border); background: var(--surface); &:hover { border-color: rgba(212,160,23,0.5); transform: translateY(-2px); }">
            <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-lg" style="background: rgba(212,160,23,0.08);">
              <svg class="h-5 w-5" style="color: var(--primary);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold" style="color: var(--text);">Limited visibility</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">School owners and administrators lack real-time insight into academic performance, financial health, and operational efficiency.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Solution -->
    <section id="modules" class="px-6 py-20">
      <div class="mx-auto max-w-6xl">
        <div class="mb-14 text-center">
          <p class="mb-2 text-xs font-semibold uppercase tracking-widest" style="color: var(--secondary);">The Solution</p>
          <h2 class="mb-4 text-3xl font-bold md:text-4xl" style="color: var(--text);">One platform. Every module your school needs.</h2>
          <p class="mx-auto max-w-2xl" style="color: var(--text-muted);">Amakio digitises every aspect of school administration so you can focus on what matters — educating students.</p>
        </div>
        <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          <div class="rounded-xl border p-6 transition-all" style="border-color: var(--card-border); background: var(--surface-2); &:hover { border-color: var(--secondary); transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,0.3); }">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg" style="background: rgba(212,160,23,0.08);">
              <svg class="h-5 w-5" style="color: var(--primary);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>
            </div>
            <h3 class="mb-2 text-base font-semibold" style="color: var(--text);">Student Management</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Complete digital profiles, attendance tracking, academic history, and medical records — always accessible.</p>
          </div>
          <div class="rounded-xl border p-6 transition-all" style="border-color: var(--card-border); background: var(--surface-2); &:hover { border-color: var(--secondary); transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,0.3); }">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg" style="background: rgba(212,160,23,0.08);">
              <svg class="h-5 w-5" style="color: var(--primary);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <h3 class="mb-2 text-base font-semibold" style="color: var(--text);">Staff Management</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Teacher profiles, lesson allocations, attendance, performance tracking, and payroll management.</p>
          </div>
          <div class="rounded-xl border p-6 transition-all" style="border-color: var(--card-border); background: var(--surface-2); &:hover { border-color: var(--secondary); transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,0.3); }">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg" style="background: rgba(212,160,23,0.08);">
              <svg class="h-5 w-5" style="color: var(--primary);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
            </div>
            <h3 class="mb-2 text-base font-semibold" style="color: var(--text);">Results & Assessments</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Create exams, record scores, compute GPA and class positions, and generate PDF report cards instantly.</p>
          </div>
          <div class="rounded-xl border p-6 transition-all" style="border-color: var(--card-border); background: var(--surface-2); &:hover { border-color: var(--secondary); transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,0.3); }">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg" style="background: rgba(212,160,23,0.08);">
              <svg class="h-5 w-5" style="color: var(--primary);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
            </div>
            <h3 class="mb-2 text-base font-semibold" style="color: var(--text);">CBT System</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Computer-Based Testing for continuous assessments and exams. Auto-graded, instant results, secure delivery.</p>
          </div>
          <div class="rounded-xl border p-6 transition-all" style="border-color: var(--card-border); background: var(--surface-2); &:hover { border-color: var(--secondary); transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,0.3); }">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg" style="background: rgba(212,160,23,0.08);">
              <svg class="h-5 w-5" style="color: var(--primary);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            </div>
            <h3 class="mb-2 text-base font-semibold" style="color: var(--text);">Finance Management</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Fee structures, payment tracking, instalments, outstanding balances, and multi-gateway payment integration.</p>
          </div>
          <div class="rounded-xl border p-6 transition-all" style="border-color: var(--card-border); background: var(--surface-2); &:hover { border-color: var(--secondary); transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,0.3); }">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg" style="background: rgba(212,160,23,0.08);">
              <svg class="h-5 w-5" style="color: var(--primary);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"/></svg>
            </div>
            <h3 class="mb-2 text-base font-semibold" style="color: var(--text);">Parent Portal</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Parents access results, attendance, fee status, and school communication through a dedicated portal with unique passcodes.</p>
          </div>
          <div class="rounded-xl border p-6 transition-all" style="border-color: var(--card-border); background: var(--surface-2); &:hover { border-color: var(--secondary); transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,0.3); }">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg" style="background: rgba(212,160,23,0.08);">
              <svg class="h-5 w-5" style="color: var(--primary);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
            </div>
            <h3 class="mb-2 text-base font-semibold" style="color: var(--text);">Communication Hub</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Send announcements, results, and alerts via SMS, email, or WhatsApp. Two-way communication with parents and staff.</p>
          </div>
          <div class="rounded-xl border p-6 transition-all" style="border-color: var(--card-border); background: var(--surface-2); &:hover { border-color: var(--secondary); transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,0.3); }">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg" style="background: rgba(212,160,23,0.08);">
              <svg class="h-5 w-5" style="color: var(--primary);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
            </div>
            <h3 class="mb-2 text-base font-semibold" style="color: var(--text);">Learning Management</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Share lesson notes, assignments, and learning materials. Students access content anytime, anywhere.</p>
          </div>
          <div class="rounded-xl border p-6 transition-all" style="border-color: var(--card-border); background: var(--surface-2); &:hover { border-color: var(--secondary); transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,0.3); }">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg" style="background: rgba(212,160,23,0.08);">
              <svg class="h-5 w-5" style="color: var(--primary);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            </div>
            <h3 class="mb-2 text-base font-semibold" style="color: var(--text);">Analytics Dashboard</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Real-time insights into academic performance, financial health, attendance trends, and operational metrics.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Schools Choose -->
    <section class="border-y px-6 py-20" style="border-color: var(--border); background: var(--surface-2);">
      <div class="mx-auto max-w-6xl">
        <div class="mb-14 text-center">
          <h2 class="mb-4 text-3xl font-bold md:text-4xl" style="color: var(--text);">Why schools choose Amakio</h2>
          <p class="mx-auto max-w-2xl" style="color: var(--text-muted);">Purpose-built for educational institutions that demand reliability, simplicity, and real results.</p>
        </div>
        <div class="grid gap-5 md:grid-cols-3">
          <div class="rounded-xl border p-7 text-center" style="border-color: var(--card-border); background: var(--surface);">
            <p class="text-4xl font-extrabold" style="color: var(--text);">10+</p>
            <p class="mt-1 text-sm font-medium" style="color: var(--text);">Integrated modules</p>
            <p class="mt-1 text-sm" style="color: var(--text-muted);">Everything from admissions to analytics in one place.</p>
          </div>
          <div class="rounded-xl border p-7 text-center" style="border-color: var(--card-border); background: var(--surface);">
            <p class="text-4xl font-extrabold" style="color: var(--text);">100%</p>
            <p class="mt-1 text-sm font-medium" style="color: var(--text);">Data ownership</p>
            <p class="mt-1 text-sm" style="color: var(--text-muted);">Your school's data belongs to you. Isolated databases, encrypted storage.</p>
          </div>
          <div class="rounded-xl border p-7 text-center" style="border-color: var(--card-border); background: var(--surface);">
            <p class="text-4xl font-extrabold" style="color: var(--text);">Zero</p>
            <p class="mt-1 text-sm font-medium" style="color: var(--text);">Technical skills required</p>
            <p class="mt-1 text-sm" style="color: var(--text-muted);">Designed for school administrators, not IT professionals.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Analytics Showcase -->
    <section class="px-6 py-20">
      <div class="mx-auto max-w-6xl">
        <div class="flex flex-col items-center gap-10 md:flex-row">
          <div class="md:w-1/2">
            <p class="mb-2 text-xs font-semibold uppercase tracking-widest" style="color: var(--secondary);">Insights at a glance</p>
            <h2 class="mb-4 text-3xl font-bold md:text-4xl" style="color: var(--text);">Data-driven decisions, delivered in real time</h2>
            <p class="mb-6 leading-relaxed" style="color: var(--text-muted);">
              Amakio's analytics dashboard gives school leaders a live view of every key metric — academic performance, financial position, attendance trends, and operational efficiency. Make informed decisions without digging through reports.
            </p>
            <ul class="space-y-3 text-sm" style="color: var(--text-muted);">
              <li class="flex items-center gap-2">
                <svg class="h-4 w-4 flex-shrink-0" style="color: var(--secondary);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Class performance comparison across terms
              </li>
              <li class="flex items-center gap-2">
                <svg class="h-4 w-4 flex-shrink-0" style="color: var(--secondary);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Fee collection rates and outstanding balances
              </li>
              <li class="flex items-center gap-2">
                <svg class="h-4 w-4 flex-shrink-0" style="color: var(--secondary);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Attendance trends by class, week, or term
              </li>
              <li class="flex items-center gap-2">
                <svg class="h-4 w-4 flex-shrink-0" style="color: var(--secondary);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Exportable reports for board meetings and regulators
              </li>
            </ul>
