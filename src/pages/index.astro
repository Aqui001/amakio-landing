---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Amakio — School Management for Modern Africa" description="Amakio helps African schools manage students, teachers, fees, admissions, and reports from one powerful platform.">
  <nav class="fixed top-0 left-0 right-0 z-50 border-b backdrop-blur-xl" style="border-color: var(--border); background: rgba(15,15,19,0.8);">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <span class="text-lg font-bold tracking-tight" style="color: var(--text);">amakio</span>
      <div class="flex items-center gap-6">
        <a href="/about" class="text-sm font-medium transition-colors" style="color: var(--text-muted); &:hover { color: var(--text); }">About</a>
        <a href="#features" class="text-sm font-medium transition-colors" style="color: var(--text-muted); &:hover { color: var(--text); }">Features</a>
        <a href="#pricing" class="text-sm font-medium transition-colors" style="color: var(--text-muted); &:hover { color: var(--text); }">Pricing</a>
        <a href="https://amakio-frontend.vercel.app" class="rounded-lg px-4 py-2 text-sm font-semibold text-white transition-all" style="background: var(--accent); &:hover { transform: translateY(-1px); box-shadow: 0 8px 24px rgba(124,58,237,0.3); }">Get Started</a>
      </div>
    </div>
  </nav>

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden px-6 pt-32 pb-24 text-center">
      <div class="pointer-events-none absolute inset-0" style="background: radial-gradient(ellipse 600px 400px at 50% 0%, rgba(124,58,237,0.12), transparent);"></div>
      <div class="mx-auto max-w-4xl">
        <div class="mb-6 inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-sm font-medium" style="background: rgba(124,58,237,0.1); color: var(--accent-light); border: 1px solid rgba(124,58,237,0.2);">
          Built for African schools
        </div>
        <h1 class="mb-6 text-5xl font-extrabold leading-tight tracking-tight md:text-6xl lg:text-7xl" style="color: var(--text);">
          School management<br />
          <span style="background: linear-gradient(135deg, var(--accent-light), var(--accent)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">for modern Africa</span>
        </h1>
        <p class="mx-auto mb-10 max-w-2xl text-lg leading-relaxed" style="color: var(--text-muted);">
          From student records and fee tracking to admissions and report cards — Amakio gives you one platform to run your school with clarity and control.
        </p>
        <div class="flex items-center justify-center gap-4">
          <a href="https://amakio-frontend.vercel.app" class="rounded-lg px-8 py-3.5 text-base font-semibold text-white transition-all" style="background: var(--accent); &:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(124,58,237,0.35); }">
            Start free
          </a>
          <a href="#features" class="rounded-lg px-8 py-3.5 text-base font-semibold transition-all" style="color: var(--text); border: 1px solid var(--border); &:hover { border-color: var(--accent); }">
            See how it works
          </a>
        </div>
        <p class="mt-4 text-sm" style="color: var(--text-dim);">No credit card needed. Free for small schools.</p>
      </div>
    </section>

    <!-- Social Proof -->
    <section class="border-y px-6 py-12" style="border-color: var(--border);">
      <div class="mx-auto max-w-6xl text-center">
        <p class="mb-6 text-xs font-semibold uppercase tracking-widest" style="color: var(--text-dim);">Trusted by educators across Nigeria</p>
        <div class="flex flex-wrap items-center justify-center gap-x-12 gap-y-4 text-lg font-semibold" style="color: var(--text-dim);">
          <span>50+ Schools</span>
          <span>10,000+ Students</span>
          <span>500+ Teachers</span>
          <span>4.8★ Rating</span>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="px-6 py-24">
      <div class="mx-auto max-w-6xl">
        <div class="mb-16 text-center">
          <h2 class="mb-4 text-3xl font-bold md:text-4xl" style="color: var(--text);">Everything you need to run your school</h2>
          <p class="mx-auto max-w-2xl" style="color: var(--text-muted);">No more scattered spreadsheets, lost records, or manual report cards. Amakio brings every piece of your school together.</p>
        </div>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          <div class="group rounded-xl border p-6 transition-all" style="border-color: var(--border); background: var(--surface-2); &:hover { border-color: var(--accent); transform: translateY(-4px); box-shadow: 0 12px 40px rgba(124,58,237,0.1); }">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg" style="background: rgba(124,58,237,0.1);">
              <svg class="h-6 w-6" style="color: var(--accent-light);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold" style="color: var(--text);">Student & Teacher Profiles</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Complete digital records for every student and teacher. Attendance, performance, contact info — always a click away.</p>
          </div>
          <div class="group rounded-xl border p-6 transition-all" style="border-color: var(--border); background: var(--surface-2); &:hover { border-color: var(--accent); transform: translateY(-4px); box-shadow: 0 12px 40px rgba(124,58,237,0.1); }">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg" style="background: rgba(124,58,237,0.1);">
              <svg class="h-6 w-6" style="color: var(--accent-light);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold" style="color: var(--text);">Exams & Results</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Create exams, record scores, and generate report cards instantly. Track class averages and identify trends across terms.</p>
          </div>
          <div class="group rounded-xl border p-6 transition-all" style="border-color: var(--border); background: var(--surface-2); &:hover { border-color: var(--accent); transform: translateY(-4px); box-shadow: 0 12px 40px rgba(124,58,237,0.1); }">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg" style="background: rgba(124,58,237,0.1);">
              <svg class="h-6 w-6" style="color: var(--accent-light);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold" style="color: var(--text);">Fee Management</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Track fee structures, payment records, and outstanding balances. Integrate with Paystack and Flutterwave for online collections.</p>
          </div>
          <div class="group rounded-xl border p-6 transition-all" style="border-color: var(--border); background: var(--surface-2); &:hover { border-color: var(--accent); transform: translateY(-4px); box-shadow: 0 12px 40px rgba(124,58,237,0.1); }">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg" style="background: rgba(124,58,237,0.1);">
              <svg class="h-6 w-6" style="color: var(--accent-light);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold" style="color: var(--text);">Admissions Portal</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Accept online applications, manage campaigns, schedule entrance exams, and track every applicant from submission to enrollment.</p>
          </div>
          <div class="group rounded-xl border p-6 transition-all" style="border-color: var(--border); background: var(--surface-2); &:hover { border-color: var(--accent); transform: translateY(-4px); box-shadow: 0 12px 40px rgba(124,58,237,0.1); }">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg" style="background: rgba(124,58,237,0.1);">
              <svg class="h-6 w-6" style="color: var(--accent-light);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold" style="color: var(--text);">Nursery School Module</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Developmental tracking, milestone monitoring, and age-appropriate assessments for early childhood education programs.</p>
          </div>
          <div class="group rounded-xl border p-6 transition-all" style="border-color: var(--border); background: var(--surface-2); &:hover { border-color: var(--accent); transform: translateY(-4px); box-shadow: 0 12px 40px rgba(124,58,237,0.1); }">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg" style="background: rgba(124,58,237,0.1);">
              <svg class="h-6 w-6" style="color: var(--accent-light);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"/></svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold" style="color: var(--text);">Reports & Analytics</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Generate PDF report cards, transcript records, and school performance analytics. Make data-driven decisions with real-time insights.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section id="pricing" class="border-y px-6 py-24" style="border-color: var(--border);">
      <div class="mx-auto max-w-6xl">
        <div class="mb-16 text-center">
          <h2 class="mb-4 text-3xl font-bold md:text-4xl" style="color: var(--text);">Simple, transparent pricing</h2>
          <p class="mx-auto max-w-2xl" style="color: var(--text-muted);">Start free. Upgrade when you grow. No hidden fees, no long-term contracts.</p>
        </div>
        <div class="mx-auto grid max-w-4xl gap-6 md:grid-cols-3">
          <div class="rounded-xl border p-8 transition-all" style="border-color: var(--border); background: var(--surface-2); &:hover { transform: translateY(-4px); }">
            <h3 class="mb-2 text-lg font-semibold" style="color: var(--text);">Starter</h3>
            <p class="mb-1 text-sm" style="color: var(--text-muted);">For small schools</p>
            <div class="mb-6">
              <span class="text-4xl font-bold" style="color: var(--text);">Free</span>
            </div>
            <ul class="mb-8 space-y-3 text-sm" style="color: var(--text-muted);">
              <li class="flex items-center gap-2">
                <svg class="h-4 w-4" style="color: var(--accent-light);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Up to 50 students
              </li>
              <li class="flex items-center gap-2">
                <svg class="h-4 w-4" style="color: var(--accent-light);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Core record keeping
              </li>
              <li class="flex items-center gap-2">
                <svg class="h-4 w-4" style="color: var(--accent-light);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Basic reporting
              </li>
            </ul>
            <a href="https://amakio-frontend.vercel.app/signup" class="block rounded-lg py-3 text-center text-sm font-semibold transition-all" style="color: var(--text); border: 1px solid var(--border); &:hover { border-color: var(--accent); }">Get started</a>
          </div>
          <div class="relative rounded-xl border-2 p-8 transition-all" style="border-color: var(--accent); background: var(--surface-2); transform: scale(1.05);">
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full px-4 py-1 text-xs font-semibold text-white" style="background: var(--accent);">Most popular</span>
            <h3 class="mb-2 text-lg font-semibold" style="color: var(--text);">School</h3>
            <p class="mb-1 text-sm" style="color: var(--text-muted);">For growing schools</p>
            <div class="mb-6">
              <span class="text-4xl font-bold" style="color: var(--text);">Coming soon</span>
            </div>
            <ul class="mb-8 space-y-3 text-sm" style="color: var(--text-muted);">
              <li class="flex items-center gap-2">
                <svg class="h-4 w-4" style="color: var(--accent-light);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Unlimited students
              </li>
              <li class="flex items-center gap-2">
                <svg class="h-4 w-4" style="color: var(--accent-light);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Admissions portal
              </li>
              <li class="flex items-center gap-2">
                <svg class="h-4 w-4" style="color: var(--accent-light);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Payment integration
              </li>
              <li class="flex items-center gap-2">
                <svg class="h-4 w-4" style="color: var(--accent-light);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Priority support
              </li>
            </ul>
            <a href="https://amakio-frontend.vercel.app/signup" class="block rounded-lg py-3 text-center text-sm font-semibold text-white transition-all" style="background: var(--accent); &:hover { box-shadow: 0 8px 24px rgba(124,58,237,0.3); }">Get notified</a>
          </div>
          <div class="rounded-xl border p-8 transition-all" style="border-color: var(--border); background: var(--surface-2); &:hover { transform: translateY(-4px); }">
            <h3 class="mb-2 text-lg font-semibold" style="color: var(--text);">Enterprise</h3>
            <p class="mb-1 text-sm" style="color: var(--text-muted);">For school groups</p>
            <div class="mb-6">
              <span class="text-4xl font-bold" style="color: var(--text);">Custom</span>
            </div>
            <ul class="mb-8 space-y-3 text-sm" style="color: var(--text-muted);">
              <li class="flex items-center gap-2">
                <svg class="h-4 w-4" style="color: var(--accent-light);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Multi-campus
              </li>
              <li class="flex items-center gap-2">
                <svg class="h-4 w-4" style="color: var(--accent-light);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Dedicated support
              </li>
              <li class="flex items-center gap-2">
                <svg class="h-4 w-4" style="color: var(--accent-light);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Custom integrations
              </li>
            </ul>
            <a href="mailto:officialaquilo@outlook.com" class="block rounded-lg py-3 text-center text-sm font-semibold transition-all" style="color: var(--text); border: 1px solid var(--border); &:hover { border-color: var(--accent); }">Contact us</a>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="px-6 py-24">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-12 text-center text-3xl font-bold" style="color: var(--text);">Frequently asked questions</h2>
        <div class="space-y-4">
          <details class="group rounded-xl border p-6" style="border-color: var(--border); background: var(--surface-2);">
            <summary class="flex cursor-pointer items-center justify-between font-medium" style="color: var(--text);">
              What is Amakio?
              <svg class="h-5 w-5 transition-transform group-open:rotate-45" style="color: var(--text-muted);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            </summary>
            <p class="mt-4 text-sm leading-relaxed" style="color: var(--text-muted);">Amakio is a school management platform built for African schools. It helps you manage students, teachers, fees, exams, admissions, and report cards from a single dashboard.</p>
          </details>
          <details class="group rounded-xl border p-6" style="border-color: var(--border); background: var(--surface-2);">
            <summary class="flex cursor-pointer items-center justify-between font-medium" style="color: var(--text);">
              Is Amakio really free?
              <svg class="h-5 w-5 transition-transform group-open:rotate-45" style="color: var(--text-muted);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            </summary>
            <p class="mt-4 text-sm leading-relaxed" style="color: var(--text-muted);">Yes. The Starter plan is completely free for schools with up to 50 students. No credit card required. We believe small schools should have access to quality management tools.</p>
          </details>
          <details class="group rounded-xl border p-6" style="border-color: var(--border); background: var(--surface-2);">
            <summary class="flex cursor-pointer items-center justify-between font-medium" style="color: var(--text);">
              Do I need technical skills to use it?
              <svg class="h-5 w-5 transition-transform group-open:rotate-45" style="color: var(--text-muted);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            </summary>
            <p class="mt-4 text-sm leading-relaxed" style="color: var(--text-muted);">Not at all. Amakio is designed for school administrators and teachers. If you can use a smartphone, you can use Amakio. Sign up and start adding your school data immediately.</p>
          </details>
          <details class="group rounded-xl border p-6" style="border-color: var(--border); background: var(--surface-2);">
            <summary class="flex cursor-pointer items-center justify-between font-medium" style="color: var(--text);">
              Is my school data secure?
              <svg class="h-5 w-5 transition-transform group-open:rotate-45" style="color: var(--text-muted);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            </summary>
            <p class="mt-4 text-sm leading-relaxed" style="color: var(--text-muted);">Every school gets its own isolated database. Data is encrypted in transit, and access is protected by JWT authentication. Your school's data belongs to your school alone.</p>
          </details>
          <details class="group rounded-xl border p-6" style="color: var(--border); background: var(--surface-2);">
            <summary class="flex cursor-pointer items-center justify-between font-medium" style="color: var(--text);">
              Can parents access their child's results?
              <svg class="h-5 w-5 transition-transform group-open:rotate-45" style="color: var(--text-muted);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            </summary>
            <p class="mt-4 text-sm leading-relaxed" style="color: var(--text-muted);">Yes. Parents receive a unique passcode to view their child's results, attendance, and fee status through the parent portal. Teachers also get their own sign-in with a passcode.</p>
          </details>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="border-y px-6 py-24 text-center" style="border-color: var(--border);">
      <div class="mx-auto max-w-2xl">
        <h2 class="mb-4 text-3xl font-bold md:text-4xl" style="color: var(--text);">Ready to bring your school online?</h2>
        <p class="mb-8 text-lg" style="color: var(--text-muted);">Join schools across Nigeria using Amakio to manage students, track performance, and simplify administration.</p>
        <a href="https://amakio-frontend.vercel.app/signup" class="inline-block rounded-lg px-10 py-4 text-lg font-semibold text-white transition-all" style="background: var(--accent); &:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(124,58,237,0.35); }">
          Start free — no credit card
        </a>
      </div>
    </section>
  </main>

  <footer class="px-6 py-12" style="background: var(--surface-2);">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 md:flex-row">
      <span class="text-sm font-semibold" style="color: var(--text);">amakio</span>
      <div class="flex items-center gap-6 text-sm" style="color: var(--text-dim);">
        <a href="/about" class="transition-colors" style="&:hover { color: var(--text-muted); }">About</a>
        <a href="mailto:officialaquilo@outlook.com" class="transition-colors" style="&:hover { color: var(--text-muted); }">Contact</a>
        <span>&copy; {new Date().getFullYear()} Amakio</span>
      </div>
    </div>
  </footer>
</Layout>
